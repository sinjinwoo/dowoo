# docker-compose.yml이 참조하는 환경변수. 복사해서 .env로 저장 후 값을 채우세요.
# .env는 git에 커밋하지 마세요 (repo-root .gitignore에 추가 필요).

DB_NAME=dowoo
DB_USER=dowoo
DB_PASSWORD=change-me

# Core API <-> AI API 내부 전용 통신 토큰 (Phase 3/4에서 사용)
INTERNAL_TOKEN=change-me

# api_keys.encrypted_key AES-256-GCM 암호화 마스터키 (32바이트 이상 랜덤 값 권장, Phase 2에서 사용)
API_KEY_ENCRYPTION_SECRET=change-me-32-bytes-minimum

# JWT 액세스 토큰 서명 시크릿 (최소 32바이트 랜덤 값 권장, 운영 배포 전 반드시 재설정)
JWT_SECRET=change-me-32-bytes-minimum
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=1800

# 리프레시 토큰(HttpOnly 쿠키) 유효기간(일)
REFRESH_TOKEN_VALIDITY_DAYS=14

# 리프레시 토큰 쿠키 Secure 속성 - HTTPS(리버스 프록시 뒤) 배포 시에만 true로 변경
COOKIE_SECURE=false
