# docker-compose.prod.yml이 참조하는 환경변수. 복사해서 .env로 저장한 뒤 값을 채우세요.
#   cp .env.example .env
# .env는 git에 커밋하지 마세요 (repo-root .gitignore에 이미 등록되어 있음).

# Postgres DB 이름/계정 - 그대로 둬도 무방
DB_NAME=dowoo
DB_USER=dowoo

# ↓↓↓ 아래 네 개는 기본값이 없습니다 - 반드시 값을 채워야 앱이 기동됩니다 ↓↓↓

# Postgres 비밀번호
DB_PASSWORD=CHANGE_ME

# Core API <-> AI API 내부 전용 통신 토큰 (외부에 노출되지 않는 두 컨테이너 사이 값이지만 랜덤 값으로 설정)
INTERNAL_TOKEN=CHANGE_ME

# 사용자가 등록한 Gemini API 키를 암호화하는 마스터키. 32바이트 이상 랜덤 값 권장.
API_KEY_ENCRYPTION_SECRET=CHANGE_ME

# 로그인 액세스 토큰(JWT) 서명 시크릿. 32바이트 이상 랜덤 값 권장.
JWT_SECRET=CHANGE_ME

# 위 네 개는 아래 명령으로 랜덤 값을 만들어 채우면 됩니다:
#   openssl rand -hex 32

# 앱 접속 포트. 예: 다른 서비스가 이미 8080을 쓰고 있다면 3000으로 바꾸고
# http://localhost:3000 으로 접속하면 됨(프론트 재빌드 불필요 - 같은 오리진에서 서빙되므로).
CORE_API_PORT=8080

# 받아올 이미지 태그. 특정 버전으로 고정하거나 롤백할 때 v1.0.0 같은 버전 태그로 지정.
DOWOO_IMAGE_TAG=latest
